{
  "name": "mychamps-bot",
  "version": "1.0.0",
  "description": "MyChamps Discord Bot - Team attendance, scheduling, reminders, and randomisation",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build:dashboard && npm run build:server",
    "build:server": "tsc",
    "build:dashboard": "vite build --config vite.dashboard.config.ts",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "deploy-commands": "node dist/deploy-commands.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "discord.js": "^14.18.0",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "prisma": "^6.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "^22.15.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.25.0",
    "prettier": "^3.8.2",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.31.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.4",
    "vue": "^3.5.35"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
